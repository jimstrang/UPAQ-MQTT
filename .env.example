# Copy to .env and fill in. .env is gitignored.

# UniFi Protect controller (local login)
PROTECT_HOST=unifi.example.com
PROTECT_USER=your-protect-user
PROTECT_PASS=your-protect-password

# MQTT broker (HA Mosquitto add-on)
MQTT_HOST=10.0.0.5
MQTT_PORT=1883
MQTT_USER=your-mqtt-user
MQTT_PASS=your-mqtt-password

DISCOVERY_PREFIX=homeassistant
